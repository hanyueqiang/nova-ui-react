{
  "name": "nova-ui-react",
  "version": "1.0.0",
  "description": "A modern, highly customizable AI UI component library for React",
  "main": "dist/index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
